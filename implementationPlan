### 6.4. Nuovo hook `useUserBots`

```typescript
// hooks/use-user-bots.ts
export function useUserBots(allBots: BotConfig[], user: UserData | null) {
  return useMemo(() => {
    if (!user || !allBots.length) return [];
    if (user.role === 'superadmin') return allBots;
    
    // admin e operator: solo bot nel proprio botId
    return allBots.filter(bot => user.botId?.includes(bot.botId));
  }, [user, allBots]);
}
```

