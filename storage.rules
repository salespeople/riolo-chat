
service firebase.storage {
  match /b/riolo-chat.firebasestorage.app/o {
    
    // Secure rule for user-specific uploads.
    // Only the owner can write, but any authenticated user can read.
    match /uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared rule for quick reply attachments.
    // Any authenticated user can read and write to this folder.
    match /quickReplies/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
